+"""Backup utilities."""
+
+from __future__ import annotations
+
+import subprocess
+
+
+def archive_directory(path: str, output: str) -> int:
+    """Tar-gzip a directory to an output file. Returns process exit code."""
+    return subprocess.run(
+        f"tar czf {output} {path}",
+        shell=True,
+        check=False,
+    ).returncode
